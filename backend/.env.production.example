# PostPilot AI -- Production Environment Variables
# Copy this to Railway environment variables (Settings -> Variables)

# Database (Railway PostgreSQL -- auto-provided as DATABASE_URL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/railway

# Security -- generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-64-char-hex-secret-key-here

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Facebook App (from developers.facebook.com)
FACEBOOK_APP_ID=1234567890
FACEBOOK_APP_SECRET=abcdef1234567890abcdef1234567890

# CORS -- your Vercel frontend URL
ALLOWED_ORIGINS=["https://your-app.vercel.app"]

# Optional: Token expiry (default 24h = 1440 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
