DATABASE_URL=postgresql://user:password@localhost:5432/postpilot
SECRET_KEY=your-super-secret-key-change-this
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
ALLOWED_ORIGINS=["http://localhost:5173","https://your-frontend.vercel.app"]

# AI Provider Config
AI_TEXT_PROVIDER=openai         # openai | gemini
AI_TEXT_MODEL=gpt-4o            # gpt-4o | gemini-1.5-pro
AI_MINI_MODEL=gpt-4o-mini       # gpt-4o-mini | gemini-1.5-flash
AI_IMAGE_PROVIDER=openai        # openai | gemini
AI_IMAGE_MODEL=dall-e-3         # dall-e-3 | imagen-3.0-generate-001

# API Keys
OPENAI_API_KEY=sk-proj-...      # required if using openai provider
GEMINI_API_KEY=AIza...          # required if using gemini provider
